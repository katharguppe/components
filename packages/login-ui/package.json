{
  "name": "@saas-auth/login-ui",
  "version": "1.0.0",
  "description": "React Login UI Component with Web Component wrapper",
  "type": "module",
  "main": "dist/login-ui.js",
  "module": "dist/login-ui.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/login-ui.js",
      "types": "./dist/index.d.ts"
    },
    "./web-component": {
      "import": "./dist/auth-login.js",
      "types": "./dist/web-component/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:wc": "vite build --mode web-component",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^23.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.1.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "SaaS Platform Team",
  "license": "UNLICENSED"
}
